{
  "name": "CRO Daily Loop — 9am",
  "active": true,
  "nodes": [
    {
      "id": "cron-cro",
      "name": "Cron 9am EST",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [240, 300],
      "parameters": {
        "rule": { "interval": [{ "field": "cronExpression", "expression": "0 14 * * *" }] }
      }
    },
    {
      "id": "run-cro",
      "name": "Trigger CRO Loop",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [460, 300],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.BACKEND_URL }}/cron/department-work?department=cro",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "x-cron-secret", "value": "={{ $env.CRON_SECRET }}" }]
        }
      }
    },
    {
      "id": "log-cro",
      "name": "Log Result",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [680, 300],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/notifications_log",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Authorization", "value": "=Bearer {{ $env.SUPABASE_SERVICE_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ channel: 'system', message: 'CRO daily loop triggered', status: 'sent' }) }}"
      }
    }
  ],
  "connections": {
    "Cron 9am EST": { "main": [[{ "node": "Trigger CRO Loop", "type": "main", "index": 0 }]] },
    "Trigger CRO Loop": { "main": [[{ "node": "Log Result", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" },
  "tags": ["cron", "autonomous", "cro"]
}
