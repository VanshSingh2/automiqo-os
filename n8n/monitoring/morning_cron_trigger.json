{
  "settings": {
    "executionOrder": "v1"
  },
  "name": "morning_cron_trigger",
  "connections": {
    "Cron": {
      "main": [
        [
          {
            "node": "Trigger Morning Briefing All Businesses",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Trigger Morning Briefing All Businesses": {
      "main": [
        [
          {
            "node": "Respond",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "nodes": [
    {
      "id": "cron-cron",
      "name": "Cron",
      "type": "n8n-nodes-base.cron",
      "position": [
        240,
        300
      ],
      "parameters": {
        "cronExpression": "0 7 * * *"
      },
      "typeVersion": 1
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.BACKEND_URL }}/cron/morning-briefing",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-cron-secret",
              "value": "={{ $env.CRON_SECRET }}"
            }
          ]
        }
      },
      "id": "briefing-all-biz",
      "type": "n8n-nodes-base.httpRequest",
      "name": "Trigger Morning Briefing All Businesses",
      "position": [
        460,
        300
      ],
      "typeVersion": 4
    },
    {
      "id": "res-cron",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [
        1560,
        200
      ],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"success\": true}"
      },
      "typeVersion": 1
    }
  ]
}