    "Create Referral Code":{"main":[[{"node":"Send Code via SMS","type":"main","index":0}]]},
    "Send Code via SMS":{"main":[[{"node":"Update Task","type":"main","index":0}]]},
    "Redeem Referral":{"main":[[{"node":"Update Task","type":"main","index":0}]]},
    "Update Task":{"main":[[{"node":"Respond","type":"main","index":0}]]}
  },
  "settings":{"executionOrder":"v1"},"tags":["revenue","referrals"]
