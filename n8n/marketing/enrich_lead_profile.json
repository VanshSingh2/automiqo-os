{
  "name": "Enrich Lead Profile",
  "nodes": [
    {
      "id": "1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "parameters": {
        "path": "enrich_lead_profile",
        "httpMethod": "POST"
      },
      "position": [
        250,
        300
      ]
    },
    {
      "id": "2",
      "name": "Validate",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "// Enrich a lead with additional data: social profiles, employee count, tech stack.\nconst d = $input.first().json;\nif (!d.business_id) throw new Error('Missing business_id');\nreturn [$input.first()];"
      },
      "position": [
        450,
        300
      ]
    },
    {
      "id": "3",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { status: 'ok', workflow: 'enrich_lead_profile' } }}"
      },
      "position": [
        650,
        300
      ]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Validate",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Validate": {
      "main": [
        [
          {
            "node": "Respond",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {}
}