# App
APP_ENV=development
JWT_SECRET=change-me-32-chars-minimum
FRONTEND_URL=http://localhost:3000
CRON_SECRET=change-me-random-secret

# AI Models
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=
NVIDIA_API_KEY=nvapi-...
CEO_MODEL=openai/gpt-4.1
DEPT_MODEL=openai/gpt-4o-mini

# Supabase — dashboard.supabase.com → project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# Redis
REDIS_URL=redis://redis:6379

# n8n
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance/webhook
N8N_API_KEY=eyJ...

# Twilio — console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# VAPI — app.vapi.ai
VAPI_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VAPI_PHONE_NUMBER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VAPI_INBOUND_ASSISTANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VAPI_OUTBOUND_ASSISTANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VAPI_AB_ASSISTANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Cal.com — cal.com/settings/developer/api-keys
CAL_COM_API_KEY=cal_live_...
CAL_COM_BASE_URL=https://api.cal.com/v2
CAL_COM_API_VERSION=2024-08-13
CAL_COM_EVENT_TYPE_30MIN=
CAL_COM_EVENT_TYPE_15MIN=

# Resend — resend.com/api-keys
RESEND_API_KEY=re_...

# Serper.dev (lead scraping) — serper.dev
SERPER_API_KEY=

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_BUSINESS_ID=00000000-0000-0000-0000-000000000001
BACKEND_URL=http://localhost:8000
